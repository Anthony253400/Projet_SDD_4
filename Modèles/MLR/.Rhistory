library(nnet)
set.seed(123)
setwd("C:/MAMP/htdocs/Projet_SDD_4/Modèles/MLR")
# Quelle variable on utlise pour la prediciton ?
# Comment bien repartir les données d'entrainement et de test ?
# Comment bien évaluer le model ?
getwd()
df <- read.csv("../../data/public_data_waste_fee.csv")
dechets_colonnes <- c("organic", "paper", "glass", "wood", "metal", "plastic", "raee", "texile", "other")
df[dechets_colonnes][is.na(df[dechets_colonnes])] <- 0
index <- sample(1:nrow(df), size = 0.8 * nrow(df))
train_set <- df[index, ]
test_set  <- df[-index, ]
Y_train <- as.matrix(train_set[, dechets_colonnes])
modele_dechets <- multinom(Y_train ~ gdp + pden + alt + pop + urb,
data = train_set,
maxit = 500)
summary(modele_dechets)
# 1. Prédire les catégories sur le jeu de test
predictions <- predict(modele_dechets, newdata = test_set)
# 2. Créer la matrice de confusion
table_matrice <- table(Prédit = predictions, Réel = test_set$vrai_label)
# 1. Identifier la catégorie réelle majoritaire pour chaque ligne du test_set
# On cherche quelle colonne parmi 'dechets_colonnes' a la valeur max pour chaque ligne
vrai_label <- dechets_colonnes[max.col(test_set[, dechets_colonnes], ties.method = "first")]
# 2. Maintenant, on peut créer la matrice de confusion
# On vérifie que les deux ont la même longueur
if(length(predictions) == length(vrai_label)) {
table_matrice <- table(Prédit = predictions, Réel = vrai_label)
print(table_matrice)
# 3. Calcul de la précision globale (Accuracy)
accuracy <- sum(diag(table_matrice)) / sum(table_matrice)
print(paste("Précision globale :", round(accuracy * 100, 2), "%"))
} else {
print("Erreur : Les longueurs ne correspondent toujours pas.")
}
accuracy <- sum(diag(table_matrice)) / sum(table_matrice)
print(paste("Précision globale :", round(accuracy * 100, 2), "%"))
