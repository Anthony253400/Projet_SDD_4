res <- summary(fit_train)
beta_hat <- res$coefficients[,"Estimate"]
# Prédiction pour l'individu i = 100
y_pred <- beta_hat[1] + beta_hat[2]*x_1[100] + beta_hat[3]*x_2[100]
# Calcul de l'erreur de prédiction
y_sim[100] - y_pred
