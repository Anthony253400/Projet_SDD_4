knitr::opts_chunk$set(echo = TRUE)
(mu=c(1,-1))
(Sigma=matrix(c(3,2,2,4),nrow = 2, ncol = 2, byrow = TRUE))
n0 <- 100
# Génération aléatoire de X_1
X_ech <- rnorm(n=n0, mean=mu[1], sd=sqrt(Sigma[1,1]))
# Moyenne et variance empirique (= moyenne et variance de l'échantillon)
summary(X_ech)
var(X_ech)
#Représenter la densité empirique de l’échantillon.
# aide sur la fonction hist()
?hist
# densité de probabilité EMPIRIQUE (en nombre d'occurences)
hist(X_ech, freq=T)
# densité de probabilité EMPIRIQUE (ramené à des valeurs de densité, telle que l'aire sous la courbe soit égale à 1)
hist(X_ech, freq=F)
#fX(2)
dnorm(x=2 ,mean=mu[1], sd=sqrt(Sigma[1,1]))
#fX(1)
dnorm(x=1 ,mean=mu[1], sd=sqrt(Sigma[1,1]))
#fX(0)
dnorm(x=0 ,mean=mu[1], sd=sqrt(Sigma[1,1]))
# distribution empirique (densité)
hist(X_ech, freq=F)
#séquence de valeurs de x
newx <- seq(-5,5, by=0.05)
# ajout de la courbe de densité théorique
lines(newx, dnorm(x=newx ,mean=mu[1], sd=sqrt(Sigma[1,1])), lty=2)
X_ech <- rnorm(n=1000, mean=mu[1], sd=sqrt(Sigma[1,1]))
hist(X_ech, freq=F, xlim=c(-5,5), ylim=c(0,0.3))
lines(newx, dnorm(x=newx ,mean=mu[1], sd=sqrt(Sigma[1,1])), lty=2)
# A compléter
Y_ech <- rnorm(n=n0, mean=mu[2], sd=sqrt(Sigma[2,2]))
# si nécessaire, installer le package
# install.packages("mvtnorm")
library(mvtnorm)
#aide sur le package
?mvtnorm
#aide sur la fonction
?rmvnorm
XY_ech<-rmvnorm(n=n0, mean = mu, sigma = Sigma)
# moments empiriques
# moyenne des X
mean(XY_ech[,1])
# moyenne des Y
mean(XY_ech[,2])
# opération par colonne (MARGIN = 2)
apply(XY_ech, MARGIN =  2, FUN = mean)
apply(XY_ech, MARGIN =  2, FUN = var)
#matrice de covariance EMPIRIQUE
cov(XY_ech)
#matrice de corrélation EMPIRIQUE
cor(XY_ech)
# nuage de points
plot(XY_ech[,1],XY_ech[,2])s
