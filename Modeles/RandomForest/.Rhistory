if(nrow(df_temp) < 25) next
set.seed(42)
sample_idx <- sample(seq_len(nrow(df_temp)), size = floor(0.8 * nrow(df_temp)))
train_data <- df_temp[sample_idx, ]
test_data  <- df_temp[-sample_idx, ]
