## Predictors
set.seed(2026)
n <- 100
x_1 <- runif(n, min = -2, max = 2)
x_2 <- runif(n, min = 0, max = 4)
## Générer le bruit eps
eps <- rnorm(n, mean = 0, sd = 5) #sd (écart-type) a un impact sur R² ()
## Générer les n valeurs y_sim
beta_0 <- -2; beta_1 <- 3; beta_2 <- -1
y_sim <- beta_0 + beta_1 * x_1 + beta_2 * x_2 + eps
fit <- lm(y_sim ~ x_1+x_2)
summary(fit)
