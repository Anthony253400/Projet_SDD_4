df <- read.csv("../../data/public_data_waste_fee.csv")
dechets_colonnes <- c("organic", "paper", "glass", "wood", "metal", "plastic", "raee", "texile", "other")
df[dechets_colonnes][is.na(df[dechets_colonnes])] <- 0
df$vrai_label <- dechets_colonnes[max.col(df[, dechets_colonnes])]
df_equilibre <- df[df$vrai_label != "organic", ]
df_organic_reduit <- df[df$vrai_label == "organic", ][1:200, ] # On limite l'organique à 200 lignes
df_final <- rbind(df_equilibre, df_organic_reduit)
index <- sample(1:nrow(df), size = 0.8 * nrow(df))
train_set <- df[index, ]
test_set  <- df[-index, ]
Y_train <- as.matrix(train_set[, dechets_colonnes])
modele_dechets <- multinom(Y_train ~ log(pop) + gdp + wage + alt + urb,
data = train_set,
maxit = 500)
summary(modele_dechets)
table_matrice <- table(Prédit = predictions, Réel = vrai_label)
predictions <- predict(modele_dechets, newdata = test_set)
vrai_label <- dechets_colonnes[max.col(test_set[, dechets_colonnes])]
accuracy <- sum(diag(table_matrice)) / sum(table_matrice)
print(table_matrice)
print(paste("Précision globale :", round(accuracy * 100, 2), "%"))
library(nnet)
set.seed(123)
# 2. Paramètres de la validation croisée
k <- 5 # Nombre de "plis" (folds)
folds <- cut(seq(1, nrow(df_final)), breaks = k, labels = FALSE)
folds <- sample(folds) # On mélange les indices
# Pour stocker les précisions de chaque étape
accuracies <- c()
# 3. Boucle de validation croisée
for(i in 1:k){
# Séparation Train / Test pour ce pli
test_indices <- which(folds == i, arr.ind = TRUE)
train_cv <- df_final[-test_indices, ]
test_cv  <- df_final[test_indices, ]
# Entraînement
Y_train_cv <- as.matrix(train_cv[, dechets_colonnes])
model_cv <- multinom(Y_train_cv ~ log(pop) + gdp + wage + alt + urb,
data = train_cv, trace = FALSE, maxit = 200)
# Prédiction et Évaluation
preds_cv <- predict(model_cv, newdata = test_cv)
vrai_label_cv <- dechets_colonnes[max.col(test_cv[, dechets_colonnes])]
# Calcul de l'accuracy pour ce pli
acc <- sum(preds_cv == vrai_label_cv) / length(vrai_label_cv)
accuracies <- c(accuracies, acc)
print(paste("Pli", i, "- Précision :", round(acc * 100, 2), "%"))
}
# 4. Résultat final moyen
print("--- RÉSULTATS FINAUX ---")
print(paste("Précision moyenne (CV) :", round(mean(accuracies) * 100, 2), "%"))
print(paste("Écart-type (stabilité) :", round(sd(accuracies) * 100, 2), "%"))
for(i in 1:k){
# 1. Séparation
test_indices <- which(folds == i, arr.ind = TRUE)
train_cv <- df_final[-test_indices, ]
test_cv  <- df_final[test_indices, ]
# 2. Entraînement
Y_train_cv <- as.matrix(train_cv[, dechets_colonnes])
model_cv <- multinom(Y_train_cv ~ log(pop) + gdp + wage + alt + urb,
data = train_cv, trace = FALSE, maxit = 200)
# 3. Prédiction
preds_cv <- predict(model_cv, newdata = test_cv)
# 4. Label Réel (on s'assure que c'est du texte propre)
vrai_label_cv <- dechets_colonnes[max.col(test_cv[, dechets_colonnes])]
# 5. Calcul de l'accuracy SANS NA
# On force en caractère pour être sûr que la comparaison marche
comparaison <- as.character(preds_cv) == as.character(vrai_label_cv)
# On calcule la moyenne en ignorant les NA éventuels
acc <- mean(comparaison, na.rm = TRUE)
accuracies <- c(accuracies, acc)
print(paste("Pli", i, "- Précision :", round(acc * 100, 2), "%"))
}
print(rapport_classes)
# Calcul des métriques par classe
diag_vector <- diag(table_matrice) # Les vrais positifs
row_sums <- rowSums(table_matrice) # Total des prédictions par classe
col_sums <- colSums(table_matrice) # Total des étiquettes réelles par classe
precision <- diag_vector / row_sums
rappel <- diag_vector / col_sums
f1_score <- 2 * (precision * rappel) / (precision + rappel)
# Création d'un tableau récapitulatif
rapport_classes <- data.frame(
Precision = round(precision * 100, 2),
Rappel = round(rappel * 100, 2),
F1_Score = round(f1_score * 100, 2)
)
print(rapport_classes)
